<?xml version="1.0" encoding="UTF-8"?>
<configuration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://www.exoplatform.org/xml/ns/kernel_1_3.xsd http://www.exoplatform.org/xml/ns/kernel_1_3.xsd"
               xmlns="http://www.exoplatform.org/xml/ns/kernel_1_3.xsd">

    <!-- 1. AlfrescoSettingImpl en premier car Constants en dépend -->
    <component>
        <key>org.exoplatform.alfresco.rest.api.AlfrescoSettingService</key>
        <type>org.exoplatform.alfresco.rest.api.AlfrescoSettingImpl</type>
    </component>

    <!-- 2. Constants dépend de AlfrescoSettingImpl -->
    <component>
        <type>org.exoplatform.alfresco.rest.util.Constants</type>
    </component>

    <!-- 3. AlfrescoServiceImpl dépend de Constants -->
    <component>
        <key>org.exoplatform.alfresco.rest.api.AlfrescoService</key>
        <type>org.exoplatform.alfresco.rest.api.AlfrescoServiceImpl</type>
    </component>
    <component>
        <type>org.exoplatform.alfresco.rest.service.AlfrescoRestService</type>
    </component>

    <!-- 4. AlfrescoSettingsRestService dépend de AlfrescoSettingImpl -->
    <component>
        <type>org.exoplatform.alfresco.rest.service.AlfrescoSettingsRestService</type>
    </component>

    <import>war:/conf/custom-extension/bundle-configuration.xml</import>
    <import>war:/conf/custom-extension/portal-configuration.xml</import>
</configuration>
