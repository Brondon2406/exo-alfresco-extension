{
  "extends": [
    "eslint-config-meedsio"
  ],
  "rules": {
    "vue/multi-word-component-names": "off",
    "no-prototype-builtins": ["warn"],
    "vue/no-mutating-props": ["warn"],
    "indent": "off",
    "vue/html-indent": "off",
    "vuejs-accessibility/no-static-element-interactions": "off",
    "no-console": "off"
  },
  "globals": {
  }
}
